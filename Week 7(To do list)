<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>🚀 ProTask - Advanced Productivity Suite</title>
    <style>
        :root {
            --primary: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            --secondary: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
            --success: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
            --warning: linear-gradient(135deg, #fa709a 0%, #fee140 100%);
            --danger: linear-gradient(135deg, #ff6b6b 0%, #ee5a24 100%);
            --dark: #2c3e50;
            --light: #ecf0f1;
            --shadow: 0 20px 40px rgba(0,0,0,0.1);
            --shadow-hover: 0 25px 50px rgba(0,0,0,0.15);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        *::selection {
            background: #4facfe;
            color: white;
        }

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
            background: var(--primary);
            min-height: 100vh;
            padding: 20px;
            line-height: 1.6;
        }

        .app-container {
            max-width: 1400px;
            margin: 0 auto;
            background: rgba(255, 255, 255, 0.98);
            backdrop-filter: blur(20px);
            border-radius: 30px;
            box-shadow: var(--shadow);
            overflow: hidden;
            animation: slideIn 0.6s ease-out;
        }

        @keyframes slideIn {
            from { opacity: 0; transform: translateY(30px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .header {
            background: var(--success);
            color: white;
            padding: 40px;
            text-align: center;
            position: relative;
            overflow: hidden;
        }

        .header::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100"><defs><pattern id="grain" width="100" height="100" patternUnits="userSpaceOnUse"><circle cx="25" cy="25" r="1" fill="white" opacity="0.1"/><circle cx="75" cy="75" r="1.5" fill="white" opacity="0.05"/></pattern></defs><rect width="100" height="100" fill="url(%23grain)"/></svg>');
            opacity: 0.3;
        }

        .header h1 {
            font-size: 3.2em;
            font-weight: 800;
            margin-bottom: 10px;
            position: relative;
            z-index: 1;
        }

        .header p {
            font-size: 1.3em;
            opacity: 0.9;
            position: relative;
            z-index: 1;
        }

        .nav-tabs {
            display: flex;
            background: #f8f9fa;
            border-bottom: 1px solid #e9ecef;
            overflow-x: auto;
            scrollbar-width: none;
        }

        .nav-tabs::-webkit-scrollbar { display: none; }

        .nav-tab {
            flex: 1;
            min-width: 160px;
            padding: 20px;
            text-align: center;
            cursor: pointer;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            font-weight: 600;
            font-size: 0.95em;
            position: relative;
            border: none;
            background: none;
        }

        .nav-tab:hover {
            background: rgba(79, 172, 254, 0.1);
            color: #4facfe;
        }

        .nav-tab.active {
            background: white;
            color: #4facfe;
            box-shadow: 0 -2px 20px rgba(79, 172, 254, 0.3);
        }

        .nav-tab.active::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: var(--success);
        }

        .tab-content {
            display: none;
            padding: 40px;
            min-height: 500px;
        }

        .tab-content.active {
            display: block;
            animation: fadeIn 0.4s ease-in;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .input-group {
            display: flex;
            gap: 15px;
            margin-bottom: 30px;
            align-items: end;
        }

        .form-input, .form-select {
            padding: 16px 20px;
            border: 2px solid #e9ecef;
            border-radius: 16px;
            font-size: 16px;
            flex: 1;
            font-family: inherit;
            transition: all 0.3s;
            background: white;
        }

        .form-input:focus, .form-select:focus {
            outline: none;
            border-color: #4facfe;
            box-shadow: 0 0 0 4px rgba(79, 172, 254, 0.1);
            transform: translateY(-2px);
        }

        .priority-select {
            min-width: 120px;
        }

        .btn {
            padding: 16px 32px;
            border: none;
            border-radius: 16px;
            background: var(--success);
            color: white;
            cursor: pointer;
            font-size: 16px;
            font-weight: 600;
            font-family: inherit;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            box-shadow: 0 4px 15px rgba(79, 172, 254, 0.3);
        }

        .btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 25px rgba(79, 172, 254, 0.4);
        }

        .btn:active {
            transform: translateY(-1px);
        }

        .btn-danger { background: var(--danger); box-shadow: 0 4px 15px rgba(255, 107, 107, 0.3); }
        .btn-danger:hover { box-shadow: 0 8px 25px rgba(255, 107, 107, 0.4); }
        .btn-success { background: var(--success); }
        .btn-warning { background: var(--warning); }

        .task-grid {
            display: grid;
            gap: 20px;
            grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
        }

        .task-card {
            background: white;
            border-radius: 20px;
            padding: 25px;
            box-shadow: var(--shadow);
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            position: relative;
            overflow: hidden;
            cursor: grab;
        }

        .task-card:hover {
            transform: translateY(-8px);
            box-shadow: var(--shadow-hover);
        }

        .task-card.dragging {
            opacity: 0.7;
            transform: rotate(5deg) scale(1.05);
        }

        .task-card.priority-high { border-left: 6px solid #ff6b6b; }
        .task-card.priority-medium { border-left: 6px solid #ffa726; }
        .task-card.priority-low { border-left: 6px solid #4caf50; }
        .task-card.completed { opacity: 0.7; }
        .task-card.completed .task-title { text-decoration: line-through; }

        .task-header {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 15px;
        }

        .task-checkbox {
            width: 24px;
            height: 24px;
            accent-color: #4facfe;
            cursor: pointer;
        }

        .priority-badge {
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 0.8em;
            font-weight: 700;
            text-transform: uppercase;
        }

        .priority-high { background: rgba(255, 107, 107, 0.2); color: #ff6b6b; }
        .priority-medium { background: rgba(255, 167, 38, 0.2); color: #ffa726; }
        .priority-low { background: rgba(76, 175, 80, 0.2); color: #4caf50; }

        .task-title {
            font-size: 1.3em;
            font-weight: 700;
            color: var(--dark);
            margin-bottom: 8px;
            line-height: 1.3;
        }

        .task-meta {
            display: flex;
            gap: 20px;
            font-size: 0.9em;
            color: #666;
            margin-bottom: 15px;
        }

        .task-actions {
            display: flex;
            gap: 10px;
        }

        .btn-icon {
            width: 40px;
            height: 40px;
            border-radius: 12px;
            font-size: 18px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .pomodoro-container {
            max-width: 500px;
            margin: 0 auto;
            text-align: center;
        }

        .timer-display {
            font-size: 5em;
            font-weight: 900;
            background: linear-gradient(135deg, #ffecd2 0%, #fcb69f 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin: 30px 0;
            font-family: 'Courier New', monospace;
            font-variant-numeric: tabular-nums;
        }

        .calendar-grid {
            display: grid;
            grid-template-columns: repeat(7, 1fr);
            gap: 8px;
            margin-top: 30px;
        }

        .calendar-header {
            grid-column: 1 / -1;
            display: grid;
            grid-template-columns: repeat(7, 1fr);
            gap: 8px;
            margin-bottom: 10px;
        }

        .calendar-day {
            aspect-ratio: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 12px;
            cursor: pointer;
            transition: all 0.3s;
            font-weight: 600;
            position: relative;
        }

        .calendar-day:hover {
            transform: scale(1.1);
            background: rgba(79, 172, 254, 0.1);
        }

        .calendar-day.today {
            background: var(--danger);
            color: white;
            box-shadow: 0 0 20px rgba(255, 107, 107, 0.4);
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            margin-top: 30px;
        }

        .stat-card {
            background: white;
            padding: 30px;
            border-radius: 20px;
            text-align: center;
            box-shadow: var(--shadow);
            transition: all 0.3s;
        }

        .stat-card:hover {
            transform: translateY(-5px);
        }

        .stat-number {
            font-size: 3em;
            font-weight: 800;
            line-height: 1;
        }

        .search-filter {
            display: flex;
            gap: 15px;
            margin-bottom: 30px;
            flex-wrap: wrap;
        }

        .filter-chips {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
        }

        .filter-chip {
            padding: 8px 16px;
            background: #f8f9fa;
            border: 2px solid transparent;
            border-radius: 25px;
            cursor: pointer;
            transition: all 0.3s;
            font-size: 0.9em;
        }

        .filter-chip.active {
            background: #4facfe;
            color: white;
            border-color: #4facfe;
        }

        @media (max-width: 768px) {
            body { padding: 10px; }
            .header h1 { font-size: 2.2em; }
            .input-group { flex-direction: column; }
            .task-grid { grid-template-columns: 1fr; }
            .nav-tabs { flex-wrap: wrap; }
            .nav-tab { min-width: 100px; }
        }

        .drag-placeholder {
            height: 100px;
            background: rgba(79, 172, 254, 0.2);
            border: 3px dashed #4facfe;
            border-radius: 20px;
            margin: 20px 0;
            animation: pulse 2s infinite;
        }

        @keyframes pulse {
            0%, 100% { opacity: 0.5; }
            50% { opacity: 1; }
        }

        .notification {
            position: fixed;
            top: 20px;
            right: 20px;
            padding: 20px 30px;
            background: var(--success);
            color: white;
            border-radius: 15px;
            box-shadow: var(--shadow);
            transform: translateX(400px);
            transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            z-index: 1000;
        }

        .notification.show {
            transform: translateX(0);
        }
    </style>
</head>
<body>
    <div class="app-container">
        <div class="header">
            <h1>🚀 ProTask</h1>
            <p>AI-Powered Productivity Suite • Drag & Drop • Smart Analytics</p>
        </div>

        <div class="nav-tabs" id="navTabs">
            <button class="nav-tab active" data-tab="dashboard">Dashboard</button>
            <button class="nav-tab" data-tab="tasks">All Tasks</button>
            <button class="nav-tab" data-tab="pomodoro">Pomodoro</button>
            <button class="nav-tab" data-tab="calendar">Calendar</button>
            <button class="nav-tab" data-tab="analytics">Analytics</button>
        </div>

        <!-- Dashboard -->
        <div id="dashboard" class="tab-content active">
            <div class="input-group">
                <input type="text" class="form-input" id="quickTask" placeholder="Quick add task... (hit Enter)">
                <select class="form-select priority-select" id="quickPriority">
                    <option value="low">Low</option>
                    <option value="medium" selected>Medium</option>
                    <option value="high">High</option>
                </select>
                <button class="btn" onclick="addQuickTask()">Add Task</button>
            </div>
            
            <div class="stats-grid">
                <div class="stat-card">
                    <div class="stat-number" id="todayTotal">0</div>
                    <div>Tasks Today</div>
                </div>
                <div class="stat-card">
                    <div class="stat-number" id="todayCompleted">0</div>
                    <div>Completed Today</div>
                </div>
                <div class="stat-card">
                    <div class="stat-number" id="streak">7</div>
                    <div>Current Streak</div>
                </div>
                <div class="stat-card">
                    <div class="stat-number" id="focusTime">2h 45m</div>
                    <div>Total Focus Time</div>
                </div>
            </div>

            <h3 style="margin: 30px 0 20px 0; font-size: 1.5em;">Today's Priority Tasks</h3>
            <ul id="todayTasks" class="task-list"></ul>
        </div>

        <!-- All Tasks -->
        <div id="tasks" class="tab-content">
            <div class="search-filter">
                <input type="text" class="form-input" id="taskSearch" placeholder="🔍 Search tasks...">
                <div class="filter-chips">
                    <div class="filter-chip active" data-filter="all">All</div>
                    <div class="filter-chip" data-filter="pending">Pending</div>
                    <div class="filter-chip" data-filter="completed">Completed</div>
                    <div class="filter-chip" data-filter="high">High</div>
                    <div class="filter-chip" data-filter="overdue">Overdue</div>
                </div>
            </div>
            
            <div class="input-group">
                <input type="text" class="form-input" id="taskInput" placeholder="Enter detailed task...">
                <input type="datetime-local" class="form-input" id="taskDate">
                <select class="form-select priority-select" id="taskPriority">
                    <option value="low">Low Priority</option>
                    <option value="medium" selected>Medium Priority</option>
                    <option value="high">High Priority</option>
                </select>
                <button class="btn" onclick="addTask()">Add Task</button>
            </div>
            
            <div id="taskGrid" class="task-grid"></div>
        </div>

        <!-- Pomodoro -->
        <div id="pomodoro" class="tab-content">
            <div class="pomodoro-container">
                <div class="timer-display" id="timerDisplay">25:00</div>
                <div class="input-group" style="justify-content: center; max-width: 400px; margin: 0 auto;">
                    <input type="number" class="form-input" id="timerMinutes" value="25" min="1" max="60" style="width: 100px;">
                    <button class="btn" id="startBtn" onclick="startTimer()">Start</button>
                    <button class="btn" id="pauseBtn" onclick="pauseTimer()" style="display:none;">Pause</button>
                    <button class="btn btn-danger" onclick="resetTimer()">Reset</button>
                </div>
                <div style="margin-top: 20px; font-size: 1.2em; color: #666;">
                    <span id="timerStatus">Ready to focus</span>
                </div>
                <div style="margin-top: 30px;">
                    <button class="btn" onclick="addPomodoroBreak()">Short Break (5m)</button>
                    <button class="btn btn-warning" onclick="addPomodoroBreak(15)">Long Break (15m)</button>
                </div>
            </div>
        </div>

        <!-- Calendar -->
        <div id="calendar" class="tab-content">
            <div class="input-group">
                <input type="text" class="form-input" id="calendarTask" placeholder="Quick task for selected date...">
                <button class="btn" onclick="addCalendarTask()">Schedule</button>
            </div>
            <div style="display: flex; gap: 20px; margin-bottom: 20px;">
                <button class="btn" onclick="prevMonth()">← Prev</button>
                <div style="flex: 1; text-align: center; font-size: 1.5em; font-weight: 700;" id="monthYear"></div>
                <button class="btn" onclick="nextMonth()">Next →</button>
            </div>
            <div class="calendar-grid">
                <div class="calendar-header">
                    <div class="calendar-day header">Sun</div>
                    <div class="calendar-day header">Mon</div>
                    <div class="calendar-day header">Tue</div>
                    <div class="calendar-day header">Wed</div>
                    <div class="calendar-day header">Thu</div>
                    <div class="calendar-day header">Fri</div>
                    <div class="calendar-day header">Sat</div>
                </div>
                <div id="calendarDays"></div>
            </div>
        </div>

        <!-- Analytics -->
        <div id="analytics" class="tab-content">
            <h3 style="margin-bottom: 30px; font-size: 1.8em;">Productivity Insights</h3>
            <div class="stats-grid">
                <div class="stat-card">
                    <div class="stat-number" style="color: #4facfe;">94%</div>
                    <div>Tasks Completed</div>
                </div>
                <div class="stat-card">
                    <div class="stat-number" style="color: #4caf50;">12/15</div>
                    <div>Weekly Goals</div>
                </div>
                <div class="stat-card">
                    <div class="stat-number" style="color: #ff9800;">3.2h</div>
                    <div>Avg Daily Focus</div>
                </div>
                <div class="stat-card">
                    <div class="stat-number" style="color: #9c27b0;">21</div>
                    <div>Day Streak</div>
                </div>
            </div>
            <div style="margin-top: 40px; padding: 30px; background: #f8f9fa; border-radius: 20px;">
                <h4>Weekly Trends</h4>
                <div style="height: 300px; background: white; border-radius: 15px; margin-top: 20px; display: flex; align-items: center; justify-content: center; color: #999; font-size: 1.2em;">
                    📊 Productivity trending upward this week!
                </div>
            </div>
        </div>
    </div>

    <div id="notification" class="notification"></div>

    <script>
        // Core Data Structures
        let tasks = JSON.parse(localStorage.getItem('proTasks')) || [];
        let timerState = { running: false, paused: false, timeLeft: 25 * 60 };
        let currentMonth = new Date().getMonth();
        let currentYear = new Date().getFullYear();
        let draggedTask = null;

        // Initialize
        document.addEventListener('DOMContentLoaded', function() {
            initTabs();
            displayTasks();
            displayTodayTasks();
            generateCalendar();
            updateTimerDisplay();
            updateStats();
        });

        // Tab Management
        function initTabs() {
            document.querySelectorAll('.nav-tab').forEach(tab => {
                tab.addEventListener('click', (e) => switchTab(e.target.dataset.tab));
            });
        }

        function switchTab(tabName) {
            document.querySelectorAll('.nav-tab').forEach(t => t.classList.remove('active'));
            document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
            
            event.target.classList.add('active');
            document.getElementById(tabName).classList.add('active');
            
            if (tabName === 'tasks') displayTasks();
            if (tabName === 'dashboard') {
                displayTodayTasks();
                updateStats();
            }
            if (tabName === 'calendar') generateCalendar();
        }

        // Task Management (Enhanced)
        function addQuickTask() {
            const text = document.getElementById('quickTask').value.trim();
            if (!text) return;
            
            const task = {
                id: Date.now(),
                text: text,
                priority: document.getElementById('quickPriority').value,
                completed: false,
                created: new Date().toISOString(),
                dueDate: new Date(new Date().setHours(23,59,59,999)).toISOString()
            };
            
            tasks.unshift(task);
            saveTasks();
            document.getElementById('quickTask').value = '';
            displayTodayTasks();
            showNotification('Task added successfully! ✅');
        }

        function addTask() {
            const text = document.getElementById('taskInput').value.trim();
            const date = document.getElementById('taskDate').value;
            const priority = document.getElementById('taskPriority').value;
            
            if (!text || !date) {
                showNotification('Please fill all fields!', 'error');
                return;
            }
            
            const task = {
                id: Date.now(),
                text: text,
                priority: priority,
                completed: false,
                created: new Date().toISOString(),
                dueDate: new Date(date).toISOString()
            };
            
            tasks.push(task);
            saveTasks();
            document.getElementById('taskInput').value = '';
            document.getElementById('taskDate').value = '';
            displayTasks();
            showNotification('Task scheduled!');
        }

        function displayTasks(filter = 'all') {
            const grid = document.getElementById('taskGrid');
            let filteredTasks = tasks;
            
            // Apply filters
            if (filter === 'pending') filteredTasks = tasks.filter(t => !t.completed);
            if (filter === 'completed') filteredTasks = tasks.filter(t => t.completed);
            if (filter === 'high') filteredTasks = tasks.filter(t => t.priority === 'high');
            if (filter === 'overdue') {
                filteredTasks = tasks.filter(t => 
                    !t.completed && new Date(t.dueDate) < new Date()
                );
            }
            
            // Sort by priority and due date
            filteredTasks.sort((a, b) => {
                const prio = { high: 3, medium: 2, low: 1 };
                return prio[b.priority] - prio[a.priority] || 
                       new Date(a.dueDate) - new Date(b.dueDate);
            });
            
            grid.innerHTML = filteredTasks.map(task => createTaskCard(task)).join('');
            initDragAndDrop();
        }

        function createTaskCard(task) {
            const isOverdue = !task.completed && new Date(task.dueDate) < new Date();
            const priorityClass = `priority-${task.priority}`;
            const completedClass = task.completed ? 'completed' : '';
            
            return `
                <div class="task-card ${priorityClass} ${completedClass}" draggable="true" data-task-id="${task.id}">
                    <div class="task-header">
                        <input type="checkbox" class="task-checkbox" ${task.completed ? 'checked' : ''} 
                               onchange="toggleTask(${task.id})">
                        <span class="priority-badge priority-${task.priority}">${task.priority.toUpperCase()}</span>
                    </div>
                    <div class="task-title">${task.text}</div>
                    <div class="task-meta">
                        <span>${new Date(task.dueDate).toLocaleDateString()}</span>
                        ${isOverdue ? '<span style="color: #ff6b6b;">⏰ Overdue</span>' : ''}
                    </div>
                    <div class="task-actions">
                        <button class="btn btn-icon" onclick="editTask(${task.id})" title="Edit">✏️</button>
                        <button class="btn btn-icon btn-danger" onclick="deleteTask(${task.id})" title="Delete">🗑️</button>
                    </div>
                </div>
            `;
        }

        function toggleTask(id) {
            const task = tasks.find(t => t.id === id);
            task.completed = !task.completed;
            task.completedAt = new Date().toISOString();
            saveTasks();
            displayTasks();
            displayTodayTasks();
            updateStats();
        }

        function deleteTask(id) {
            if (confirm('Delete this task?')) {
                tasks = tasks.filter(t => t.id !== id);
                saveTasks();
                displayTasks();
                showNotification('Task deleted.');
            }
        }

        function editTask(id) {
            const task = tasks.find(t => t.id === id);
            const newText = prompt('Edit task:', task.text);
            if (newText && newText.trim()) {
                task.text = newText.trim();
                saveTasks();
                displayTasks();
            }
        }

        // Today Tasks
        function displayTodayTasks() {
            const today = new Date().toDateString();
            const todayTasks = tasks.filter(task => {
                const taskDate = new Date(task.dueDate).toDateString();
                return taskDate === today;
            });
            
            document.getElementById('todayTasks').innerHTML = todayTasks.map(task => 
                createTaskCard(task)
            ).join('');
        }

        // Drag & Drop
        function initDragAndDrop() {
            const cards = document.querySelectorAll('.task-card');
            cards.forEach(card => {
                card.addEventListener('dragstart', (e) => {
                    draggedTask = e.target;
                    e.target.classList.add('dragging');
                });
                
                card.addEventListener('dragend', (e) => {
                    e.target.classList.remove('dragging');
                    draggedTask = null;
                });
                
                card.addEventListener('dragover', (e) => e.preventDefault());
                
                card.addEventListener('drop', (e) => {
                    e.preventDefault();
                    if (draggedTask) {
                        e.target.parentNode.insertBefore(draggedTask, e.target.nextSibling);
                    }
                });
            });
        }

        // Filter System
        document.addEventListener('click', (e) => {
            if (e.target.classList.contains('filter-chip')) {
                document.querySelectorAll('.filter-chip').forEach(chip => chip.classList.remove('active'));
                e.target.classList.add('active');
                displayTasks(e.target.dataset.filter);
            }
        });

        document.getElementById('taskSearch').addEventListener('input', (e) => {
            const search = e.target.value.toLowerCase();
            const filtered = tasks.filter(task => 
                task.text.toLowerCase().includes(search) || 
                task.priority.includes(search)
            );
            document.getElementById('taskGrid').innerHTML = filtered.map(createTaskCard).join('');
        });

        // Pomodoro Timer (Enhanced)
        function updateTimerDisplay() {
            const minutes = Math.floor(timerState.timeLeft / 60);
            const seconds = timerState.timeLeft % 60;
            document.getElementById('timerDisplay').textContent = 
                `${minutes.toString().padStart(2, '0')}:${seconds.toString().padStart(2, '0')}`;
        }

        function startTimer() {
            if (!timerState.running) {
                timerState.running = true;
                timerState.paused = false;
                document.getElementById('startBtn').style.display = 'none';
                document.getElementById('pauseBtn').style.display = 'inline-block';
                document.getElementById('timerStatus').textContent = 'Focus mode active...';
                timerLoop();
            }
        }

        let timerInterval;
        function timerLoop() {
            timerInterval = setInterval(() => {
                if (timerState.running && !timerState.paused && timerState.timeLeft > 0) {
                    timerState.timeLeft--;
                    updateTimerDisplay();
                } else if (timerState.timeLeft === 0) {
                    showNotification('Time\'s up! Great work! 🔔 Take a break.', 'success');
                    resetTimer();
                }
            }, 1000);
        }

        function pauseTimer() {
            timerState.paused = !timerState.paused;
            if (timerState.paused) {
                document.getElementById('pauseBtn').textContent = 'Resume';
                document.getElementById('timerStatus').textContent = 'Paused';
            } else {
                document.getElementById('pauseBtn').textContent = 'Pause';
                document.getElementById('timerStatus').textContent = 'Focus mode active...';
            }
        }

        function resetTimer() {
            clearInterval(timerInterval);
            const minutes = parseInt(document.getElementById('timerMinutes').value);
            timerState = { running: false, paused: false, timeLeft: minutes * 60 };
            updateTimerDisplay();
            document.getElementById('startBtn').style.display = 'inline-block';
            document.getElementById('pauseBtn').style.display = 'none';
            document.getElementById('pauseBtn').textContent = 'Pause';
            document.getElementById('timerStatus').textContent = 'Ready to focus';
        }

        function addPomodoroBreak(minutes = 5) {
            timerState.timeLeft = minutes * 60;
            updateTimerDisplay();
            document.getElementById('timerStatus').textContent = `Break time: ${minutes}min`;
            resetTimer();
        }

        // Calendar (Enhanced)
        function generateCalendar() {
            const daysContainer = document.getElementById('calendarDays');
            const monthYear = document.getElementById('monthYear');
            
            const date = new Date(currentYear, currentMonth, 1);
            monthYear.textContent = date.toLocaleDateString('en-US', { 
                month: 'long', 
                year: 'numeric' 
            });
            
            const firstDay = date.getDay();
            const daysInMonth = new Date(currentYear, currentMonth + 1, 0).getDate();
            const today = new Date();
            
            let daysHTML = '';
            
            // Empty days before first day
            for (let i = 0; i < firstDay; i++) {
                daysHTML += '<div class="calendar-day"></div>';
            }
            
            // Days of month
            for (let day = 1; day <= daysInMonth; day++) {
                const isToday = currentYear === today.getFullYear() && 
                               currentMonth === today.getMonth() && 
                               day === today.getDate();
                daysHTML += `<div class="calendar-day ${isToday ? 'today' : ''}" 
                                onclick="selectCalendarDay(${day})">${day}</div>`;
            }
            
            daysContainer.innerHTML = daysHTML;
        }

        function prevMonth() {
            currentMonth--;
            if (currentMonth < 0) {
                currentMonth = 11;
                currentYear--;
            }
            generateCalendar();
        }

        function nextMonth() {
            currentMonth++;
            if (currentMonth > 11) {
                currentMonth = 0;
                currentYear++;
            }
            generateCalendar();
        }

        function selectCalendarDay(day) {
            const selectedDate = new Date(currentYear, currentMonth, day);
            document.getElementById('calendarTask').placeholder = 
                `Task for ${selectedDate.toLocaleDateString()}...`;
            showNotification(`Selected: ${selectedDate.toLocaleDateString()}`);
        }

        function addCalendarTask() {
            const text = document.getElementById('calendarTask').value.trim();
            if (!text) return;
            
            const task = {
                id: Date.now(),
                text: text,
                priority: 'medium',
                completed: false,
                created: new Date().toISOString(),
                dueDate: new Date(currentYear, currentMonth, parseInt(document.querySelector('.today')?.textContent || 1)).toISOString()
            };
            
            tasks.push(task);
            saveTasks();
            document.getElementById('calendarTask').value = '';
            showNotification('Task scheduled for calendar date!');
        }

        // Stats & Utilities
        function updateStats() {
            const today = new Date().toDateString();
            const todayTasks = tasks.filter(task => new Date(task.dueDate).toDateString() === today);
            
            document.getElementById('todayTotal').textContent = todayTasks.length;
            document.getElementById('todayCompleted').textContent = todayTasks.filter(t => t.completed).length;
        }

        function saveTasks() {
            localStorage.setItem('proTasks', JSON.stringify(tasks));
        }

        // Keyboard Shortcuts
        document.addEventListener('keypress', function(e) {
            if (e.key === 'Enter') {
                const active = document.activeElement;
                if (active.id === 'quickTask' || active.id === 'dailyTaskInput') addQuickTask();
                if (active.id === 'taskInput') addTask();
                if (active.id === 'calendarTask') addCalendarTask();
            }
            if (e.key === ' ') {
                e.preventDefault();
                if (document.getElementById('pomodoro').classList.contains('active')) {
                    document.getElementById('startBtn').click();
                }
            }
        });

        // Notifications
        function showNotification(message, type = 'success') {
            const notification = document.getElementById('notification');
            notification.textContent = message;
            notification.className = `notification show ${type}`;
            setTimeout(() => {
                notification.classList.remove('show');
            }, 4000);
        }

        // Enter key support for quick task
        document.getElementById('quickTask').addEventListener('keypress', function(e) {
            if (e.key === 'Enter') addQuickTask();
        });
    </script>
</body>
</html>
