            <input type="checkbox" id="R" name="options" value="2">
            <label for="R">Rhythmic</label><br>
            <input type="checkbox" id="T" name="options" value="3">
            <label for="T">Traditional</label><br><br>
<label for="contact">Contact number:*</label>
<input type="number" name="contact"><br><br>
