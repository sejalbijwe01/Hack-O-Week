<h1 style="text-align:center;color:red;">SYMBIOSIS INSTITUTE OF TECHNOLOGY, NAGPUR</h1>
<h2 style="text-align:center;">Registration Form For Yoga Competition</h2>
<form action="/submit-registrztion" method="post">
<div class="form-box">
<center>
<label for="email">Email ID:*</label>
<input type="email" id="email name="email><br><br>
            <label for="name">Name of Student:*</label>
            <input type="text"  name="name"><br><br>
            <label for="prn">PRN Number:*</label>
            <input type="number"  name="prn" ><br><br>
<input type="date" name="bday"><br><br>
            <label>Section:*</label><br>
            <input type="radio" id="section" name="section" value="1">
