<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Bed & Breakfast Menu</title>
    <style>
        body {
            background: #f2f2f2;
            font-family: Georgia, serif;
            margin: 0;
            padding: 40px;
        }

        .menu {
            max-width: 900px;
            margin: auto;
            background: #fffaf0;
            padding: 40px;
            border: 2px solid #ccc;
        }

        .menu-header {
            text-align: center;
            margin-bottom: 40px;
        }

        .menu-header h1 {
            margin: 5px 0;
            font-size: 36px;
        }

        .menu-header h3 {
            margin: 0;
            font-style: italic;
            color: #666;
        }

        .section {
            margin-bottom: 35px;
        }

        .section h2 {
            text-align: center;
            border-top: 2px solid #999;
            border-bottom: 2px solid #999;
            padding: 10px 0;
            margin-bottom: 20px;
            letter-spacing: 2px;
        }

        .item {
            display: flex;
            justify-content: space-between;
            margin-bottom: 12px;
        }

        .item-name {
            font-weight: bold;
        }

        .item-desc {
            font-size: 14px;
            color: #555;
        }

        .price {
            font-weight: bold;
        }

        .menu-image {
            margin-top: 30px;
            text-align: center;
        }

        .menu-image img {
            max-width: 100%;
            border-radius: 10px;
        }
    </style>
</head>
<body>

<div class="menu">

    <div class="menu-header">
        <h1>Versatile</h1>
        
    </div>

    <div class="section">
        <h2>STARTERS</h2>

        <div class="item">
            <div>
                <div class="item-name">Chilli panner</div>
                <div class="item-desc">Crispy and juicy</div>
            </div>
            <div class="price">90.00</div>
        </div>

        <div class="item">
            <div>
                <div class="item-name">Maggie</div>
                <div class="item-desc">Masala and creamy</div>
            </div>
            <div class="price">50.00</div>
        </div>
    </div>

    <div class="section">
        <h2>SALADS</h2>

        <div class="item">
            <div>
                <div class="item-name">Mixed Fruits Salad</div>
                <div class="item-desc">Fresh watermelon, and other</div>
            </div>
            <div class="price">70.00</div>
        </div>

        <div class="item">
            <div>
                <div class="item-name">Vegetable Salad</div>
                <div class="item-desc">fresh tomato and other..</div>
            </div>
            <div class="price">70.00</div>
        </div>
    </div>

    <div class="section">
        <h2>BURGERS</h2>

        <div class="item">
            <div>
                <div class="item-name">Classic Onion Burger</div>
                <div class="item-desc"> onion, cheese, house sauce</div>
            </div>
            <div class="price">100.00</div>
        </div>

        <div class="item">
            <div>
                <div class="item-name">Vegetarian Burger</div>
                <div class="item-desc">Grilled veggie patty, fresh toppings</div>
            </div>
            <div class="price">120.00</div>
        </div>
    </div>
 <div class="section">
        <h2>DESSERT</h2>

        <div class="item">
            <div>
                <div class="item-name">Gulab Jamun</div>
              
            </div>
            <div class="price">20.00</div>
        </div>

        <div class="item">
            <div>
                <div class="item-name">Ice cream</div>
                
            </div>
            <div class="price">120.00</div>
        </div>
    </div>


    <div class="menu-image">
        <img src="mc.jpg" alt="Food Image">
    </div>

</div>

</body>
</html>
